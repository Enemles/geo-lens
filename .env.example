# Copy to .env and fill in. With no keys set, the service runs on the
# deterministic mock provider so you can try it immediately.

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Concurrency + resilience
# MAX_CONCURRENT_CALLS=5
# REQUEST_TIMEOUT_SECONDS=30
# MAX_RETRIES=2

# Cache
# CACHE_TTL_SECONDS=3600

# Database (SQLite by default; point at Postgres in prod)
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/geo_lens
